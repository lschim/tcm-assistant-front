# -------------------------------
# Node / Angular
# -------------------------------

/node_modules/
/dist/
/out-tsc/
/.angular/cache/

# Coverage reports
/coverage/

# Environment files (optional)
/src/environments/*.ts

# Angular CLI generated files
.angular/

# -------------------------------
# IDEs / Editors
# -------------------------------

.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# -------------------------------
# Logs
# -------------------------------

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------------
# OS generated files
# -------------------------------

.DS_Store
Thumbs.db

# -------------------------------
# Temporary / swap / lock files
# -------------------------------

*.tmp
*.swp
*.lock

# -------------------------------
# ESLint / Prettier / Formatting
# -------------------------------

# ESLint cache
.eslintcache

# Prettier cache
.prettierignore
.prettiercache

# Optional: if you want to ignore package-lock or yarn.lock
package-lock.json
yarn.lock

# -------------------------------
# Optional IDE specific
# -------------------------------

*.log
*.tsbuildinfo

